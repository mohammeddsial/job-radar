# ─────────────────────────────────────────────────────────────────
# Job Radar + Multi-Agent System — Environment Variables
# Copy to .env.local and fill in your values
# ─────────────────────────────────────────────────────────────────

# ── EXISTING (already configured) ────────────────────────────────
GEMINI_API_KEY=your_gemini_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
CRON_SECRET=my-super-secret-2026
AGENT_SECRET=your_agent_secret_for_api_routes
NEXT_PUBLIC_URL=https://your-app.vercel.app
NEXT_PUBLIC_AGENT_SECRET=your_agent_secret_for_api_routes

# ── AI MODELS ─────────────────────────────────────────────────────
# Groq — free, fast (used by all agents for content generation)
# Get key: https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# ── JOB SOURCES (existing) ────────────────────────────────────────
# JSearch via RapidAPI — free tier: 200 req/month
# https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=your_jsearch_key_here

# Adzuna — free: 250 req/day
# https://developer.adzuna.com
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key


# ══════════════════════════════════════════════════════════════════
# NEW: AGENT 1 — GLOBAL AGENCY LEAD HUNTER
# ══════════════════════════════════════════════════════════════════

# Apollo.io — B2B lead database
# Free tier: 50 exports/month | https://app.apollo.io/settings/integrations/api
APOLLO_API_KEY=your_apollo_key_here

# Hunter.io — Find decision-maker emails by company domain
# Free tier: 25 searches/month | https://hunter.io/api-keys
HUNTER_API_KEY=your_hunter_key_here

# SerpAPI — Google search results (for buying-intent lead mining)
# Free tier: 100 searches/month | https://serpapi.com/manage-api-key
SERPAPI_KEY=your_serpapi_key_here


# GrowthTalent — 2,700+ growth marketing roles → mine companies as web leads
# Get key: https://www.growthtalent.org/settings/api-keys  (free, verified members)
GT_API_KEY=gt_live_your_key_here

# Product Hunt — New product launches (potential clients)
# Free: https://www.producthunt.com/v2/oauth/applications
PRODUCT_HUNT_TOKEN=your_product_hunt_bearer_token


# ══════════════════════════════════════════════════════════════════
# NEW: AGENT 2 — COLD EMAIL CAMPAIGN MANAGER
# ══════════════════════════════════════════════════════════════════

# Resend — Modern email API (MUST verify your sending domain)
# Free tier: 100 emails/day, 3,000/month | https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# Your verified sending address (must match domain verified in Resend)
FROM_EMAIL=zahid@warq.io
FROM_NAME=Zahid | Warq Agency

# Resend webhook secret (for delivery events, optional but recommended)
# Set in Resend dashboard → Webhooks → signing secret
RESEND_WEBHOOK_SECRET=your_resend_webhook_secret


# ══════════════════════════════════════════════════════════════════
# EXISTING AGENTS (fill in as needed)
# ══════════════════════════════════════════════════════════════════

# ── Outreach Agent ────────────────────────────────────────────────
# LinkedIn cookie from browser DevTools (Network → li_at cookie)
LINKEDIN_COOKIE=your_li_at_cookie
LINKEDIN_CSRF=your_csrf_token
LINKEDIN_ACCESS_TOKEN=your_linkedin_oauth_token
LINKEDIN_PERSON_ID=your_linkedin_person_urn_id

# Upwork OAuth
UPWORK_OAUTH_TOKEN=your_upwork_oauth_token

# Search query for outreach agent
OUTREACH_QUERY=looking for web developer

# ── Portfolio Tracker ─────────────────────────────────────────────
# Google Search Console service account JSON path
GOOGLE_SERVICE_ACCOUNT_JSON=./google-service-account.json

# DataForSEO — backlinks data | https://dataforseo.com
DATAFORSEO_LOGIN=your_dataforseo_login
DATAFORSEO_PASSWORD=your_dataforseo_password

# Google PageSpeed API
# https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=your_pagespeed_api_key

# ── Telegram Webhook ─────────────────────────────────────────────
# Random secret for validating Telegram webhook calls
TELEGRAM_WEBHOOK_SECRET=your_random_webhook_secret
