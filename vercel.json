{
  "rewrites": [
    {
      "source": "/linkedin-jobs/:path*",
      "destination": "https://www.linkedin.com/jobs-guest/jobs/api/seeMoreJobPostings/:path*"
    }
  ],
  "crons": [
    { "path": "/api/scan",                          "schedule": "0 5 * * *"       },
    { "path": "/api/cron/agency-leads?authorization=CRON_SECRET",     "schedule": "0 6 * * 1-5"    },
    { "path": "/api/cron/email-campaigns?action=send&authorization=CRON_SECRET",  "schedule": "0 7 * * 1-5"    },
    { "path": "/api/cron/email-campaigns?action=followups&authorization=CRON_SECRET", "schedule": "0 */3 * * *" },
    { "path": "/api/cron/proposals?authorization=CRON_SECRET",        "schedule": "30 9 * * 1-5"   },
    { "path": "/api/cron/outreach?authorization=CRON_SECRET",         "schedule": "0 9,15 * * 1-5" },
    { "path": "/api/cron/social-post?authorization=CRON_SECRET",      "schedule": "0 8 * * 1,3,5"  },
    { "path": "/api/cron/social-comments?authorization=CRON_SECRET",  "schedule": "0 */2 * * *"    },
    { "path": "/api/cron/weekly-content-plan?authorization=CRON_SECRET", "schedule": "0 8 * * 0"  },
    { "path": "/api/cron/portfolio?authorization=CRON_SECRET",        "schedule": "0 7 * * *"      },
    { "path": "/api/cron/portfolio-compare?authorization=CRON_SECRET","schedule": "0 7 * * 1"      },
    { "path": "/api/cron/email-campaigns?action=weekly-report&authorization=CRON_SECRET", "schedule": "0 9 * * 1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "X-Robots-Tag",           "value": "index, follow" }
      ]
    }
  ]
}
